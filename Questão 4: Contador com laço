<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <button onclick="contar()">Mostrar os números ai</button>

  <div id="resultado"></div>

  <script>
    function contar() {
      let numeros = "";

      for (let i = 1; i <= 10; i++) {
        numeros += i + "<br>";
      }

      document.getElementById("resultado").innerHTML = numeros;
    }
  </script>
</body>
</html>
