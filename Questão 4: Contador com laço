<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Contador com Laço</title>
</head>
<body>
  <button onclick="contar()">Mostrar os números ai</button>

  <div id="resultado"></div>

  <script>
    function contar() {
      let numeros = "";

      for (let i = 1; i <= 10; i++) {
        numeros += i + "<br>";
      }

      document.getElementById("resultado").innerHTML = numeros;
    }
  </script>
</body>
</html>
